# ─── Hub params (from IntelFraud Hub admin dashboard after onboarding) ───
INSTITUTION_ID=YOUR_INSTITUTION_ID
API_KEY=YOUR_API_KEY
HMAC_SECRET=YOUR_HMAC_SECRET
HUB_API_URL=https://intelfraud.com/api/v1/signals

# ─── Local params (managed by the bank, never sent to Hub) ──────────────
BANK_SALT=your_bank_salt_minimum_32_characters_long_for_security
REGIONAL_PEPPER=hub_provided_regional_pepper_for_cross_bank_matching

# ─── Optional ───────────────────────────────────────────────────────────
GATEWAY_PORT=8080
REPORTING_THRESHOLD=10000

# Inbound auth: core banking systems must present this key on /process
# (Authorization: Bearer <key> or X-Gateway-API-Key). Strongly recommended.
INBOUND_API_KEY=

# TLS for the gateway listener (PII arrives in cleartext without it)
TLS_CERT_FILE=
TLS_KEY_FILE=
